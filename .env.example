# ============================================================
# AURORA — AI Adaptive Onboarding Engine
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Configuration (required for full LLM-powered extraction) ---
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use — gpt-4o-mini is recommended for cost/quality balance
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# API base URL — change only if using Azure OpenAI or a proxy
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Backend ---
PORT=8000
DEV_RELOAD=false   # set to true for hot-reload in development
